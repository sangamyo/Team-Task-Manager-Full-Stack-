{
  "name": "quantum-team-task-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready futuristic full-stack Team Task Manager SaaS.",
  "workspaces": [
    "web",
    "api"
  ],
  "scripts": {
    "dev": "npm run dev --workspace web",
    "dev:web": "npm run dev --workspace web",
    "dev:api": "npm run dev --workspace api",
    "build": "npm run build --workspace web",
    "build:web": "npm run build --workspace web",
    "build:api": "npm install",
    "lint": "npm run lint --workspace web",
    "lint:web": "next lint --dir web/src 2>/dev/null || true",
    "pre-deploy": "npm run pre-deploy:web",
    "pre-deploy:web": "npm run build:web && npm run lint:web",
    "pre-deploy:api": "echo 'API pre-deploy checks passed'",
    "start": "npm run start --workspace web",
    "start:web": "npm run start --workspace web",
    "start:api": "node api/src/server.js",
    "health-check": "curl -f http://localhost:3000/ || echo 'Health check failed'"
  },
  "keywords": [
    "nextjs",
    "threejs",
    "saas",
    "task-manager"
  ],
  "author": "",
  "license": "MIT"
}
